{
  "name": "bindings",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/base/bindings/src",
  "targets": {
    "typecheck-base": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm copyfiles src/bindings.cjs src/bindings.d.cts out-tsc",
        "cwd": "{projectRoot}"
      }
    },
    "deploy-artifacts": {
      "executor": "nx:run-commands",
      "options": {
        "command": "napi artifacts --cwd ./src --package-json-path ../ -o=../artifacts --npm-dir ../npm",
        "cwd": "{projectRoot}"
      }
    },
    "napi-prepublish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "napi prepublish -t npm",
        "cwd": "{projectRoot}"
      }
    },
    "nx-release-publish": {
      "executor": "@storm-software/workspace-tools:npm-publish",
      "dependsOn": ["napi-prepublish"]
    }
  },
  "tags": ["platform:node"]
}
