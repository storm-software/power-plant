{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "out-tsc/tsconfig.tsbuildinfo",
    "outDir": "./out-tsc"
  },
  "references": [{ "path": "../schema/tsconfig.lib.json" }],
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.mts",
    "src/**/*.cts",
    "types/*.d.ts",
    "package.json",
    "powerlines.config.ts",
    "powerlines.d.ts"
  ],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
