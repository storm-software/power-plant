{
  "extends": "@storm-software/workspace-tools/config/recommended.json",
  "release": {
    "groups": {
      "packages": {
        "projects": [
          "packages/base/*",
          "packages/inputs/*",
          "packages/outputs/*",
          "packages/generators/*",
          "packages/devtools/*"
        ],
        "projectsRelationship": "independent"
      },
      "native": {
        "projects": ["crates/*"],
        "projectsRelationship": "fixed",
        "changelog": {
          "createRelease": "github",
          "entryWhenNoChanges": false
        },
        "version": {
          "currentVersionResolver": "git-tag",
          "specifierSource": "conventional-commits",
          "groupPreVersionCommand": "pnpm build-native",
          "versionActions": "@storm-software/workspace-tools/release/rust-version-actions"
        },
        "releaseTag": {
          "pattern": "power-plant-rs@{version}"
        }
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "compiler": "tsgo",
        "typecheck": true,
        "build": false,
        "verboseOutput": false
      }
    },
    "@storm-software/workspace-tools/plugins/typescript",
    "@storm-software/workspace-tools/plugins/rust",
    "@storm-software/workspace-tools/plugins/typescript/untyped",
    "@storm-software/workspace-tools/plugins/typescript/tsdown",
    "@powerlines/nx/plugin"
  ],
  "sync": {
    "applyChanges": true,
    "globalGenerators": ["@nx/js:typescript-sync"]
  },
  "analytics": false
}
