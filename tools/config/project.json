{
  "name": "tools-config",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "tools/config",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": ["rm -rf tools/config/dist"]
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "mkdir -p tools/config/dist",
          "cp tools/config/.gitpod.yml tools/config/gitguardian.yml tools/config/verdaccio.yml tools/config/zizmor.yml tools/config/tsdown.shared.ts tools/config/dist/"
        ],
        "parallel": false
      }
    }
  },
  "tags": ["type:tools", "platform:node"]
}
